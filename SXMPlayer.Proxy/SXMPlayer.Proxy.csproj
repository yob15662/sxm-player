		<PackageReference Include="Blazorise.Bootstrap5" Version="2.0.2" />
		<PackageReference Include="Blazorise.Animate" Version="2.0.2" />
		<PackageReference Include="Blazorise.Charts" Version="2.0.2" />
		<PackageReference Include="Blazorise.Video" Version="2.0.2" />
		<PackageReference Include="Microsoft.Extensions.Hosting.Systemd" Version="10.0.*" />
