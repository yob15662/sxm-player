<Project Sdk="Microsoft.NET.Sdk.Web">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Blazorise.Charts.Trendline" Version="2.0.2" />
		<PackageReference Include="Blazorise.Components" Version="2.0.2" />
		<PackageReference Include="Blazorise.DataGrid" Version="2.0.2" />
		<PackageReference Include="Blazorise.Icons.FontAwesome" Version="2.0.2" />
		<PackageReference Include="Blazorise.LoadingIndicator" Version="2.0.2" />
